<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.HoraCerta" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="CustomButtonTheme">
        <item name="android:paddingVertical">15dp</item>
    </style>

    <style name="ButtonPrimary" parent="CustomButtonTheme">
        <item name="backgroundTint">#2F2E41</item>
        <item name="strokeColor">#00BFA6</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="ButtonSecondary" parent="CustomButtonTheme">
        <item name="backgroundTint">#FFFFFF</item>
        <item name="strokeColor">#00BFA6</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">#2F2E41</item>
    </style>
</resources>